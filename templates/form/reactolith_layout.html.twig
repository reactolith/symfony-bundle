{# Extends the base div layout for fallback on blocks we don't override #}
{% use "form_div_layout.html.twig" %}

{# ── Standard field rendering ──────────────────────────────────────────── #}

{% block form_row -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}field>
  {{ form_label(form) }}
  <{{ _prefix }}field-content>
    {{ form_widget(form) }}
  </{{ _prefix }}field-content>
  {{ form_help(form) }}
  {{ form_errors(form) }}
</{{ _prefix }}field>
{%- endblock %}

{%- block form_label -%}
{%- if label is not same as(false) -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- set _label_html -%}
<{{ _prefix }}field-label
{%- if id is defined %} html-for="{{ id }}"{% endif -%}
{%- if label_attr is defined %}{% for key, val in label_attr %} {{ key }}="{{ val }}"{% endfor %}{% endif -%}
>
  {{- label is not same as(null) ? (translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain)) : name|humanize -}}
</{{ _prefix }}field-label>
{%- endset -%}
{%- if label_link_url is defined and label_link_url -%}
<div class="flex items-center">
{{ _label_html }}
<a href="{{ label_link_url }}" class="ml-auto inline-block text-sm underline-offset-4 hover:underline">{{ label_link_label|default('') }}</a>
</div>
{%- else -%}
{{ _label_html }}
{%- endif -%}
{%- endif -%}
{%- endblock %}

{%- block form_widget_simple -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- if type|default('text') == 'hidden' -%}
<input type="hidden" id="{{ id }}" name="{{ full_name }}"
  {%- if value is not empty %} value="{{ value }}"{% endif -%}
  {%- for key, val in attr %} {{ key }}="{{ val }}"{% endfor -%}
/>
{%- else -%}
<{{ _prefix }}input type="{{ type|default('text') }}" id="{{ id }}" name="{{ full_name }}"
  {%- if value is not empty %} value="{{ value }}"{% endif -%}
  {%- if required %} required{% endif -%}
  {%- if disabled %} disabled{% endif -%}
  {%- if attr.placeholder is defined %} placeholder="{{ attr.placeholder }}"{% endif -%}
  {%- if attr.class is defined %} class="{{ attr.class }}"{% endif -%}
  {%- for key, val in attr %}{% if key not in ['placeholder', 'class'] %} {{ key }}="{{ val }}"{% endif %}{% endfor -%}
></{{ _prefix }}input>
{%- endif -%}
{%- endblock %}

{%- block textarea_widget -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}textarea id="{{ id }}" name="{{ full_name }}"
  {%- if value is not empty %} value="{{ value }}"{% endif -%}
  {%- if required %} required{% endif -%}
  {%- if disabled %} disabled{% endif -%}
  {%- if attr.placeholder is defined %} placeholder="{{ attr.placeholder }}"{% endif -%}
  {%- if attr.rows is defined %} rows="{{ attr.rows }}"{% endif -%}
  {%- for key, val in attr %}{% if key not in ['placeholder', 'rows'] %} {{ key }}="{{ val }}"{% endif %}{% endfor -%}
></{{ _prefix }}textarea>
{%- endblock %}

{%- block checkbox_widget -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}checkbox id="{{ id }}" name="{{ full_name }}"
  {%- if value is defined %} value="{{ value }}"{% endif -%}
  {%- if checked %} json-checked="true"{% else %} json-checked="false"{% endif -%}
  {%- if required %} required{% endif -%}
  {%- if disabled %} disabled{% endif -%}
  {%- for key, val in attr %} {{ key }}="{{ val }}"{% endfor -%}
></{{ _prefix }}checkbox>
{%- endblock %}

{%- block choice_widget_collapsed -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}select id="{{ id }}" name="{{ full_name }}"
  {%- if required %} required{% endif -%}
  {%- if disabled %} disabled{% endif -%}
>
  <{{ _prefix }}select-trigger>
    <{{ _prefix }}select-value placeholder="{{ placeholder|default('Select...') }}"></{{ _prefix }}select-value>
  </{{ _prefix }}select-trigger>
  <{{ _prefix }}select-content>
    {% if placeholder is not none and not required -%}
    <{{ _prefix }}select-item value="">{{ placeholder }}</{{ _prefix }}select-item>
    {% endif -%}
    {% for group_label, choice in choices -%}
    {% if choice is iterable -%}
    {% for sub_choice in choice -%}
    <{{ _prefix }}select-item value="{{ sub_choice.value }}"
      {%- if sub_choice.value == value %} json-selected="true"{% endif -%}
    >{{ translation_domain is same as(false) ? sub_choice.label : sub_choice.label|trans({}, translation_domain) }}</{{ _prefix }}select-item>
    {% endfor -%}
    {% else -%}
    <{{ _prefix }}select-item value="{{ choice.value }}"
      {%- if choice.value == value %} json-selected="true"{% endif -%}
    >{{ translation_domain is same as(false) ? choice.label : choice.label|trans({}, translation_domain) }}</{{ _prefix }}select-item>
    {% endif -%}
    {% endfor -%}
</{{ _prefix }}select-content>
  <input type="hidden" name="{{ full_name }}"
    {%- if value is not empty %} value="{{ value }}"{% endif -%}
  />
</{{ _prefix }}select>
{%- endblock %}

{%- block choice_widget_expanded -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- if multiple -%}
  {# Checkbox group #}
  <div id="{{ id }}" class="space-y-2">
    {%- for child in form %}
      <div class="flex items-center space-x-2">
        {{ form_widget(child) }}
        {{ form_label(child) }}
      </div>
    {%- endfor %}
  </div>
{%- else -%}
  {# Radio group #}
  <{{ _prefix }}radio-group id="{{ id }}" name="{{ full_name }}"
    {%- if value is not empty %} json-value='"{{ value }}"'{% endif -%}
    {%- if required %} required{% endif -%}
    {%- if disabled %} disabled{% endif -%}
  >
    {%- for child in form %}
      <div class="flex items-center space-x-2">
        <{{ _prefix }}radio-group-item value="{{ child.vars.value }}" id="{{ child.vars.id }}"></{{ _prefix }}radio-group-item>
        <{{ _prefix }}label for="{{ child.vars.id }}">{{ translation_domain is same as(false) ? child.vars.label : child.vars.label|trans({}, translation_domain) }}</{{ _prefix }}label>
      </div>
    {%- endfor %}
  </{{ _prefix }}radio-group>
{%- endif -%}
{%- endblock %}

{%- block button_widget -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}button type="{{ type|default('button') }}" id="{{ id }}" name="{{ full_name }}"
  {%- if disabled %} disabled{% endif -%}
  {%- if attr.variant is defined %} variant="{{ attr.variant }}"{% endif -%}
  {%- for key, val in attr %}{% if key != 'variant' %} {{ key }}="{{ val }}"{% endif %}{% endfor -%}
>{{ label is not same as(null) ? (translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain)) : name|humanize }}</{{ _prefix }}button>
{%- endblock %}

{%- block submit_widget -%}
{%- set type = type|default('submit') -%}
{{ block('button_widget') }}
{%- endblock %}

{%- block form_errors -%}
{%- if errors|length > 0 -%}
  {%- for error in errors %}
    <p class="text-sm font-medium text-destructive">{{ error.message }}</p>
  {%- endfor -%}
{%- endif -%}
{%- endblock %}

{%- block form_help -%}
{%- if help is not empty %}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
  <{{ _prefix }}field-description>{{ translation_domain is same as(false) ? help : help|trans(help_translation_parameters, translation_domain) }}</{{ _prefix }}field-description>
{%- endif -%}
{%- endblock %}

{%- block reactolith_switch_widget -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
<{{ _prefix }}switch id="{{ id }}" name="{{ full_name }}"
  {%- if checked %} json-checked="true"{% else %} json-checked="false"{% endif -%}
  {%- if required %} required{% endif -%}
  {%- if disabled %} disabled{% endif -%}
  {%- for key, val in attr %} {{ key }}="{{ val }}"{% endfor -%}
></{{ _prefix }}switch>
{%- endblock %}

{# ── CardFormType blocks ───────────────────────────────────────────────── #}

{%- block reactolith_card_start -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- set _tdomain = translation_domain|default('reactolith') -%}
<{{ _prefix }}card class="w-full max-w-sm">
{%- if card_title is defined and card_title or card_description is defined and card_description %}
  <{{ _prefix }}card-header>
    {%- if card_title is defined and card_title %}
    <{{ _prefix }}card-title>{{ _tdomain is same as(false) ? card_title : card_title|trans({}, _tdomain) }}</{{ _prefix }}card-title>
    {%- endif %}
    {%- if card_description is defined and card_description %}
    <{{ _prefix }}card-description>{{ _tdomain is same as(false) ? card_description : card_description|trans({}, _tdomain) }}</{{ _prefix }}card-description>
    {%- endif %}
  </{{ _prefix }}card-header>
{%- endif %}
  <{{ _prefix }}card-content>
    {{ block('form_start') }}
{%- endblock -%}

{%- block reactolith_card_widget -%}
    <div class="flex flex-col gap-6">
      {%- if form is rootform -%}
          {{ form_errors(form) }}
      {%- endif -%}
      {{- block('form_rows') -}}
      {{- form_rest(form) -}}
    </div>
{%- endblock -%}

{%- block reactolith_card_end -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- set _tdomain = translation_domain|default('reactolith') -%}
    {{ block('form_end') }}
    {%- if social_providers is defined and social_providers|length > 0 %}
    <div class="relative my-4">
      <div class="absolute inset-0 flex items-center">
        <{{ _prefix }}separator></{{ _prefix }}separator>
      </div>
      <div class="relative flex justify-center text-xs uppercase">
        <span class="bg-background px-2 text-muted-foreground">{{ 'Or continue with'|trans({}, _tdomain) }}</span>
      </div>
    </div>
    <div class="grid gap-4{% if social_providers|length > 1 %} grid-cols-2{% endif %}">
      {%- for provider in social_providers %}
      <a href="{{ provider.url }}">
        <{{ _prefix }}button variant="outline" class="w-full" type="button">{{ provider.name }}</{{ _prefix }}button>
      </a>
      {%- endfor %}
    </div>
    {%- endif %}
  </{{ _prefix }}card-content>
  {%- if card_footer_text is defined and card_footer_text %}
  <{{ _prefix }}card-footer>
    <p class="text-center text-sm text-muted-foreground w-full">
      {{ _tdomain is same as(false) ? card_footer_text : card_footer_text|trans({}, _tdomain) }}
      {%- if card_footer_link_url is defined and card_footer_link_url and card_footer_link_label is defined and card_footer_link_label %}
      <a href="{{ card_footer_link_url }}" class="underline underline-offset-4 hover:text-primary">{{ _tdomain is same as(false) ? card_footer_link_label : card_footer_link_label|trans({}, _tdomain) }}</a>
      {%- endif %}
    </p>
  </{{ _prefix }}card-footer>
  {%- endif %}
</{{ _prefix }}card>
{%- endblock -%}

{# ── FieldGroupType blocks ─────────────────────────────────────────────── #}

{%- block reactolith_field_group_row -%}
{{ form_widget(form) }}
{%- endblock -%}

{%- block reactolith_field_group_widget -%}
<div class="flex {{ row is defined and row ? 'flex-row' : 'flex-col' }} gap-{{ gap|default('4') }}">
  {{- block('form_rows') -}}
  {{- form_rest(form) -}}
</div>
{%- endblock -%}

{# ── SeparatorType blocks ──────────────────────────────────────────────── #}

{%- block reactolith_separator_row -%}
{%- set _prefix = reactolith_tag_prefix|default('ui-') -%}
{%- if label is not same as(false) and label -%}
<div class="relative">
  <div class="absolute inset-0 flex items-center">
    <{{ _prefix }}separator></{{ _prefix }}separator>
  </div>
  <div class="relative flex justify-center text-xs uppercase">
    <span class="bg-background px-2 text-muted-foreground">{{ translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) }}</span>
  </div>
</div>
{%- else -%}
<{{ _prefix }}separator></{{ _prefix }}separator>
{%- endif -%}
{%- endblock -%}
